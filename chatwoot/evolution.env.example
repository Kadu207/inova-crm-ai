# =============================================================================
# Inova CRM AI — Evolution API (copy to chatwoot/evolution.env)
# Profile: whatsapp-evolution | Porta host: 127.0.0.1:9416
# ADR: docs/adr/005-whatsapp-evolution-transitional.md
# =============================================================================

EVOLUTION_API_KEY=change_me_generate_openssl_rand_hex_32
EVOLUTION_SERVER_URL=http://127.0.0.1:9416

EVOLUTION_POSTGRES_DB=evolution
EVOLUTION_POSTGRES_USER=evolution
EVOLUTION_POSTGRES_PASSWORD=change_me_evolution_pg
EVOLUTION_REDIS_PASSWORD=change_me_evolution_redis

# Baileys / QR — ajustar se o WhatsApp Web exigir versão nova
EVOLUTION_PHONE_VERSION=2.3000.1023204200

# Usado por scripts/setup-evolution-instance.sh (não injetado no container)
EVOLUTION_INSTANCE_NAME=crm-whatsapp
CHATWOOT_URL=http://crm_chatwoot_rails:3000
CHATWOOT_PUBLIC_URL=https://chat-crm.inovatitech.com.br
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_TOKEN=change_me_chatwoot_user_access_token
CHATWOOT_INBOX_NAME=CRM WhatsApp Evolution
