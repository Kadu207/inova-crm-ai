# =============================================================================
# Inova CRM AI — Chatwoot (copy to chatwoot/.env)
# =============================================================================

SECRET_KEY_BASE=change_me_generate_with_openssl_rand_hex_64
FRONTEND_URL=https://chat-crm.inovatitech.com.br
RAILS_ENV=production
NODE_ENV=production
INSTALLATION_ENV=docker
FORCE_SSL=true
ENABLE_ACCOUNT_SIGNUP=false

# Postgres dedicado deste compose (serviço postgres)
# POSTGRES_USER = var do container postgres; POSTGRES_USERNAME = var do Rails/Chatwoot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=crm_chatwoot
POSTGRES_USERNAME=crm_chatwoot
POSTGRES_PASSWORD=change_me_chatwoot_postgres_password
POSTGRES_DATABASE=chatwoot_crm
DATABASE_URL=postgresql://crm_chatwoot:change_me_chatwoot_postgres_password@postgres:5432/chatwoot_crm

# Redis dedicado deste compose (serviço redis)
REDIS_PASSWORD=change_me_chatwoot_redis_password
REDIS_URL=redis://:change_me_chatwoot_redis_password@redis:6379

# E-mail (SMTP) — ajustar em produção
MAILER_SENDER_EMAIL=contato@inovatitech.com.br
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

# Webhook outbound → n8n CRM (assinatura HMAC documentada em docs/webhook-signing.md)
WEBHOOK_SECRET=change_me_webhook_secret

# Storage local (volume implícito no container; S3 opcional em fase posterior)
ACTIVE_STORAGE_SERVICE=local
