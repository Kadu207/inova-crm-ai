{
  "name": "@inova-crm/workers",
  "version": "0.1.0",
  "private": true,
  "description": "RabbitMQ domain event consumers — Inova CRM AI",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "start:dev": "ts-node src/main.ts",
    "start:leads": "node dist/leads.main.js",
    "start:pipeline": "node dist/pipeline.main.js",
    "start:billing": "node dist/billing.main.js",
    "start:ai": "node dist/ai.main.js",
    "start:audit": "node dist/audit.main.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest --testPathPattern=\\.spec\\.ts$"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "amqplib": "^0.10.5"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "jest": "^29.7.0",
    "prisma": "^6.5.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
