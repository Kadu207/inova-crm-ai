# Workers
NODE_ENV=development

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=crm.events

# Backend API (preferred for domain mutations)
API_BASE_URL=http://localhost:9401/api/v1
API_TOKEN=

# Database (optional — simple idempotent updates only)
DATABASE_URL=postgresql://crm:crm_secret@localhost:9410/inova_crm?schema=public
