# Server
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DATABASE_URL=postgresql://crm:crm_secret@localhost:9410/inova_crm?schema=public

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=crm.events

# Webhook secrets
CHATWOOT_WEBHOOK_SECRET=change-me
N8N_WEBHOOK_SECRET=change-me

# CORS
CORS_ORIGINS=http://localhost:9400
