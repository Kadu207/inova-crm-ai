# =============================================================================
# Inova CRM AI — environment template (copy to .env and fill secrets)
# =============================================================================

# --- Compose / project ---
COMPOSE_PROJECT_NAME=inova-crm

# --- PostgreSQL ---
POSTGRES_USER=inova
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=postgres
POSTGRES_APP_DB=crm
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Prisma NÃO expande ${VAR} — use URL literal. Local (compose.dev): host 127.0.0.1:9410
# Em containers: host = postgres, porta 5432
DATABASE_URL=postgresql://inova:change_me_postgres_password@127.0.0.1:9410/crm?schema=public
NEXT_PUBLIC_API_URL=http://127.0.0.1:9401
AI_API_TOKEN=change_me_ai_api_token
CHATWOOT_DATABASE_URL=postgresql://inova:change_me_postgres_password@127.0.0.1:9410/chatwoot_crm?schema=public
N8N_DATABASE_URL=postgresql://inova:change_me_postgres_password@127.0.0.1:9410/n8n_crm?schema=public

# --- Redis ---
REDIS_PASSWORD=change_me_redis_password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# --- RabbitMQ ---
RABBITMQ_USER=inova
RABBITMQ_PASSWORD=change_me_rabbitmq_password
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}/

# --- MinIO / S3-compatible storage ---
MINIO_ROOT_USER=inova_minio
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=crm-assets
MINIO_USE_SSL=false

# --- Application secrets (used by backend / workers / n8n) ---
JWT_SECRET=change_me_jwt_secret_min_32_chars
API_TOKEN=change_me_api_token_for_n8n_and_workers
WEBHOOK_SECRET=change_me_webhook_secret
N8N_ENCRYPTION_KEY=change_me_n8n_encryption_key_32c

# --- n8n (infrastructure/docker-compose.yml) ---
N8N_DB=n8n_crm
N8N_SUBDOMAIN=n8n-crm.inovatitech.com.br
API_BASE_URL=https://api-crm.inovatitech.com.br

# --- External integrations (phase 2+) ---
CHATWOOT_SECRET_KEY_BASE=
CHATWOOT_FRONTEND_URL=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# --- Observability (phase 7+) ---
SENTRY_DSN=
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

# --- Local / VPS port map (reference) ---
# FRONTEND_PORT=9400
# API_PORT=9401
# AI_PORT=9402
# CHATWOOT_PORT=9403
# N8N_PORT=9404
# MINIO_API_PORT=9405
# MINIO_CONSOLE_PORT=9406
# RABBITMQ_UI_PORT=9407
# GRAFANA_PORT=9408
# POSTGRES_HOST_PORT=9410
