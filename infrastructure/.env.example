# =============================================================================
# Inova CRM AI — infrastructure environment template
# Copy to infrastructure/.env or symlink from repo root .env
# =============================================================================

COMPOSE_PROJECT_NAME=inova-crm

POSTGRES_USER=inova
POSTGRES_PASSWORD=change_me_postgres_password
# Primary DB created by the Postgres image on first boot (must match app DB)
POSTGRES_DB=crm
POSTGRES_APP_DB=crm

REDIS_PASSWORD=change_me_redis_password

RABBITMQ_USER=inova
RABBITMQ_PASSWORD=change_me_rabbitmq_password

MINIO_ROOT_USER=inova_minio
MINIO_ROOT_PASSWORD=change_me_minio_password

JWT_SECRET=change_me_jwt_secret_min_32_chars
API_TOKEN=change_me_api_token_for_n8n_and_workers
WEBHOOK_SECRET=change_me_webhook_secret
N8N_ENCRYPTION_KEY=change_me_n8n_encryption_key_32c
AI_API_TOKEN=change_me_ai_api_token
NEXT_PUBLIC_API_URL=https://api-crm.inovatitech.com.br
CORS_ORIGINS=https://crm.inovatitech.com.br,http://127.0.0.1:9400,http://localhost:9400

# n8n (DB n8n_crm no Postgres compartilhado; fila no Redis compartilhado)
N8N_DB=n8n_crm
N8N_SUBDOMAIN=n8n-crm.inovatitech.com.br
API_BASE_URL=https://api-crm.inovatitech.com.br
WEBHOOK_URL=https://n8n-crm.inovatitech.com.br/
